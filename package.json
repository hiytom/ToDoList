{
  "name": "todo-cal",
  "private": true,
  "version": "0.0.49",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "tsc -b && vite build",
    "build:desktop": "npm run build && electron-builder --mac",
    "build:desktop:apple": "npm run build && electron-builder --mac --arm64",
    "build:desktop:intel": "npm run build && electron-builder --mac --x64",
    "preview": "vite preview"
  },
  "dependencies": {
    "framer-motion": "^11.11.9",
    "lucide-react": "^0.465.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.hiytom.todolist",
    "productName": "ToDoList",
    "icon": "build/icon.icns",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
